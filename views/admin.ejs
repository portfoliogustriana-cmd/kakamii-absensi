<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8"><title>KAKAMII Admin Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-100 p-6">
    <div class="max-w-6xl mx-auto">
        <div class="flex justify-between items-center mb-8 bg-white p-4 rounded-2xl shadow-sm border border-gray-100">
            <div class="flex items-center space-x-3">
                <img src="/logo.png" alt="Logo Kakamii" class="h-12 object-contain">
                <div>
                    <h1 class="text-2xl font-bold text-gray-800 tracking-wide">PANEL ADMIN</h1>
                    <p class="text-xs text-gray-400 font-medium">Sistem Monitoring KAKAMII</p>
                </div>
            </div>
            <div>
                <a href="/admin/download" class="bg-green-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-green-700 mr-2 text-sm shadow-sm">Unduh Excel</a>
                <a href="/" class="bg-gray-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-gray-700 text-sm">Logout</a>
            </div>
        </div>

        <% if (typeof error !== 'undefined' && error) { %><div class="bg-red-50 text-red-600 p-4 rounded-xl mb-6 text-sm font-semibold border border-red-200">⚠️ <%= error %></div><% } %>
        <% if (typeof success !== 'undefined' && success) { %><div class="bg-green-50 text-green-600 p-4 rounded-xl mb-6 text-sm font-semibold border border-green-200">✅ <%= success %></div><% } %>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white p-5 rounded-lg shadow-md">
                <h2 class="text-lg font-bold text-gray-700 mb-4">Tambah Karyawan Baru</h2>
                <form action="/admin/karyawan/tambah" method="POST" class="space-y-3 mb-4">
                    <input type="text" name="username" required placeholder="Username baru" class="w-full px-3 py-1.5 border rounded-lg text-sm">
                    <input type="text" name="password" required placeholder="Password" class="w-full px-3 py-1.5 border rounded-lg text-sm">
                    <button type="submit" class="w-full bg-black text-white py-1.5 rounded-lg text-sm font-semibold hover:bg-gray-800">Daftarkan Akun</button>
                </form>
                <h3 class="font-semibold text-sm text-gray-600 mb-2 border-t pt-3">Daftar Semua Karyawan:</h3>
                <div class="max-h-40 overflow-y-auto space-y-1">
                    <% karyawan.forEach(k => { %>
                        <div class="flex justify-between items-center p-2 bg-gray-50 rounded text-sm capitalize">
                            <span><%= k.username %></span>
                            <div class="space-x-2">
                                <button onclick="bukaModalEdit('<%= k.id %>', '<%= k.username %>', '<%= k.password %>')" class="text-blue-600 hover:underline text-xs font-medium">Edit</button>
                                <% if (k.username !== 'karyawan') { %>
                                    <a href="/admin/karyawan/hapus/<%= k.id %>" onclick="return confirm('Yakin ingin menghapus akun ini?')" class="text-red-500 hover:underline text-xs">Hapus</a>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="bg-white p-5 rounded-lg shadow-md md:col-span-2 flex flex-col justify-between">
                <div>
                    <h2 class="text-lg font-bold text-gray-700 mb-4">Aturan Lokasi & Jam Kerja</h2>
                    <form action="/admin/pengaturan" method="POST" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-gray-500 mb-1">Latitude Kantor</label>
                            <input type="text" name="lat" value="<%= config.lat %>" required class="w-full px-3 py-2 border rounded-lg text-sm">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-gray-500 mb-1">Longitude Kantor</label>
                            <input type="text" name="lon" value="<%= config.lon %>" required class="w-full px-3 py-2 border rounded-lg text-sm">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-gray-500 mb-1">Radius Batasan (Meter)</label>
                            <input type="number" name="radius" value="<%= config.radius %>" required class="w-full px-3 py-2 border rounded-lg text-sm">
                        </div>
                        <div class="grid grid-cols-2 gap-2">
                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-1">Batas Jam Masuk</label>
                                <input type="text" name="jam_masuk" value="<%= config.jam_masuk %>" required class="w-full px-3 py-2 border rounded-lg text-sm text-center font-bold text-blue-600">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-500 mb-1">Batas Jam Pulang</label>
                                <input type="text" name="jam_pulang" value="<%= config.jam_pulang %>" required class="w-full px-3 py-2 border rounded-lg text-sm text-center font-bold text-red-600">
                            </div>
                        </div>
                        <button type="submit" class="sm:col-span-2 bg-indigo-600 text-white py-2.5 rounded-lg font-bold text-sm hover:bg-indigo-700 mt-2">Simpan Aturan Kantor</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="bg-white p-5 rounded-lg shadow-md mb-8 border border-red-200">
            <h2 class="text-lg font-bold text-red-600 mb-1">🔐 Ganti Password Akun Admin</h2>
            <p class="text-xs text-gray-400 mb-4">Wajib memasukkan password lama sebelum memperbarui.</p>
            <form action="/admin/ganti-password-admin" method="POST" class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
                <div>
                    <label class="block text-xs font-bold text-gray-600 uppercase mb-1">Password Lama</label>
                    <input type="password" name="password_lama" required placeholder="••••••••" class="w-full px-4 py-2 border rounded-lg text-sm font-semibold outline-none focus:ring-2 focus:ring-red-500">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-600 uppercase mb-1">Password Baru</label>
                    <input type="password" name="password_baru" required placeholder="Ketik password baru" class="w-full px-4 py-2 border rounded-lg text-sm font-semibold outline-none focus:ring-2 focus:ring-red-500">
                </div>
                <div>
                    <button type="submit" class="w-full bg-red-600 text-white py-2 rounded-lg font-bold text-sm hover:bg-red-700 transition">Perbarui Password Admin</button>
                </div>
            </form>
        </div>

        <div class="bg-white p-5 rounded-lg shadow-md">
            <h2 class="text-lg font-bold text-gray-700 mb-4">Riwayat Kehadiran Masuk & Pulang</h2>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse text-sm">
                    <thead>
                        <tr class="bg-gray-50 border-b">
                            <th class="p-3 font-semibold text-gray-600">Foto</th>
                            <th class="p-3 font-semibold text-gray-600">Nama</th>
                            <th class="p-3 font-semibold text-gray-600">Tipe</th>
                            <th class="p-3 font-semibold text-gray-600">Waktu</th>
                            <th class="p-3 font-semibold text-gray-600">Keterangan Jam</th>
                            <th class="p-3 font-semibold text-gray-600">Jarak</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% riwayat.forEach(data => { %>
                            <tr class="border-b hover:bg-gray-50">
                                <td class="p-2">
                                    <% if (data.foto) { %>
                                        <img src="<%= data.foto %>" class="w-12 h-12 object-cover rounded-md border shadow-sm">
                                    <% } else { %> - <% } %>
                                </td>
                                <td class="p-3 font-medium text-gray-800 capitalize"><%= data.nama %></td>
                                <td class="p-3">
                                    <span class="px-2 py-0.5 text-xs font-semibold rounded-full <%= data.tipe === 'Masuk' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>"><%= data.tipe %></span>
                                </td>
                                <td class="p-3 text-gray-600"><%= data.waktu_lokal %></td>
                                <td class="p-3">
                                    <span class="px-2 py-0.5 text-xs font-bold rounded <%= data.status_waktu === 'Terlambat' || data.status_waktu === 'Pulang Cepat' ? 'bg-amber-100 text-amber-700' : 'bg-blue-100 text-blue-700' %>">
                                        <%= data.status_waktu || 'Tepat Waktu' %>
                                    </span>
                                </td>
                                <td class="p-3 text-gray-700"><%= data.jarak %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="modalEdit" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-2xl p-6 w-full max-w-sm shadow-xl">
            <h2 class="text-xl font-bold text-gray-800 mb-4">Edit Akun Karyawan</h2>
            <form action="/admin/karyawan/edit" method="POST" class="space-y-4">
                <input type="hidden" name="id" id="editId">
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Username</label>
                    <input type="text" name="username" id="editUsername" required class="w-full px-3 py-2 border rounded-xl text-base outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Password Baru</label>
                    <input type="text" name="password" id="editPassword" required class="w-full px-3 py-2 border rounded-xl text-base outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div class="flex space-x-2 pt-2">
                    <button type="button" onclick="tutupModalEdit()" class="w-1/2 bg-gray-100 text-gray-700 py-2.5 rounded-xl font-semibold text-sm hover:bg-gray-200">Batal</button>
                    <button type="submit" class="w-1/2 bg-blue-600 text-white py-2.5 rounded-xl font-semibold text-sm hover:bg-blue-700 shadow-md">Simpan</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function bukaModalEdit(id, username, password) {
            document.getElementById('editId').value = id;
            document.getElementById('editUsername').value = username;
            document.getElementById('editPassword').value = password;
            document.getElementById('modalEdit').classList.remove('hidden');
        }
        function tutupModalEdit() { document.getElementById('modalEdit').classList.add('hidden'); }
    </script>
</body>
</html>