<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Absen Karyawan</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-50 min-h-screen p-4 flex flex-col justify-between">
    <div class="w-full max-w-md mx-auto bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
        <div class="bg-black p-4 text-white flex justify-between items-center">
            <div class="flex items-center space-x-3">
                <img src="/logo.png" alt="Logo" class="h-9 bg-white p-1 rounded-lg object-contain">
                <div>
                    <p class="text-[10px] text-gray-400 uppercase font-bold tracking-wider">Karyawan</p>
                    <h2 class="text-base font-bold capitalize"><%= user %></h2>
                </div>
            </div>
            <a href="/" class="bg-gray-800 hover:bg-gray-700 px-3 py-1.5 rounded-xl text-xs font-bold transition">Keluar</a>
        </div>
        
        <div class="p-5">
            <% if (error) { %><div class="bg-red-50 text-red-600 p-3 rounded-xl mb-4 text-sm font-medium border border-red-100"><%= error %></div><% } %>
            <% if (success) { %><div class="bg-green-50 text-green-600 p-3 rounded-xl mb-4 text-sm font-medium border border-green-100"><%= success %></div><% } %>

            <p class="text-xs font-bold text-gray-500 uppercase mb-2">Verifikasi Wajah (Selfie)</p>
            <div class="mb-4 bg-gray-900 rounded-2xl overflow-hidden aspect-video relative flex items-center justify-center shadow-inner">
                <video id="webcam" autoplay playsinline class="w-full h-full object-cover"></video>
                <canvas id="canvas" class="hidden absolute top-0 left-0 w-full h-full object-cover"></canvas>
            </div>
            <button type="button" id="btnAmbilFoto" class="w-full bg-gray-100 border border-gray-200 text-gray-700 py-2.5 rounded-xl mb-6 text-sm font-bold hover:bg-gray-200 transition">📸 Ambil Foto Selfie</button>

            <form action="/absen" method="POST" enctype="multipart/form-data" class="space-y-4">
                <input type="hidden" name="nama" value="<%= user %>">
                <div>
                    <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Pilih Status Kehadiran</label>
                    <select name="tipe" class="w-full px-4 py-3 border border-gray-200 rounded-xl outline-none focus:ring-2 focus:ring-black text-base bg-white">
                        <option value="Masuk">🟢 Absen MASUK</option>
                        <option value="Pulang">🔴 Absen PULANG</option>
                    </select>
                </div>
                <input type="hidden" name="lat" id="lat"><input type="hidden" name="lon" id="lon">
                <input type="file" name="foto" id="fotoFile" class="hidden" required>
                <button type="submit" class="w-full bg-black text-white font-bold py-3.5 rounded-xl text-base hover:bg-gray-900 transition active:scale-[0.98]">Kirim Absensi Sekarang</button>
            </form>
        </div>
    </div>
    <div class="text-center text-xs text-gray-400 mt-6 font-medium">© KAKAMII Absensi System</div>

    <script>
        const video = document.getElementById('webcam'); const canvas = document.getElementById('canvas'); const btnFoto = document.getElementById('btnAmbilFoto');
        navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" } }).then(stream => video.srcObject = stream);
        btnFoto.addEventListener('click', () => {
            const ctx = canvas.getContext('2d'); canvas.width = video.videoWidth; canvas.height = video.videoHeight;
            ctx.drawImage(video, 0, 0, canvas.width, canvas.height); canvas.classList.remove('hidden');
            canvas.toBlob(blob => {
                const file = new File([blob], "selfie.jpg", { type: "image/jpeg" }); const container = new DataTransfer(); container.items.add(file);
                document.getElementById('fotoFile').files = container.files;
                btnFoto.innerText = "✅ Foto Berhasil Diambil"; btnFoto.classList.add("bg-green-50", "text-green-600", "border-green-200");
            }, 'image/jpeg');
        });
        navigator.geolocation.getCurrentPosition(p => { document.getElementById('lat').value = p.coords.latitude; document.getElementById('lon').value = p.coords.longitude; });
    </script>
</body>
</html>